<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body class="flex flex-col min-h-screen bg-slate-100">

<!-- Navbar -->
<%- include('../partials/navbar') %>

<main class="flex-grow px-6 py-10">

<!-- HEADER -->
<div class="max-w-7xl mx-auto text-center mb-10">
  <h1 class="text-3xl font-bold text-slate-900">Admin Dashboard</h1>
  <p class="text-slate-600 mt-1">
    Welcome, <span class="font-semibold text-slate-800"><%= user.name %></span>
  </p>
</div>

<!-- ================= USER OVERVIEW ================= -->
<div class="max-w-7xl mx-auto mb-10 bg-slate-50/80 backdrop-blur rounded-2xl shadow-md p-6 border border-slate-200">

  <h2 class="text-xl font-bold text-slate-900 mb-5">User Overview</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

    <div class="bg-blue-100/70 border-l-4 border-blue-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Total Users</p>
        <p class="text-2xl font-bold text-blue-700"><%= totalUsers %></p>
      </div>
      <i class="fas fa-users text-2xl text-blue-600"></i>
    </div>

    <div class="bg-green-100/70 border-l-4 border-green-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Donors</p>
        <p class="text-2xl font-bold text-green-700"><%= donors %></p>
      </div>
      <i class="fas fa-hand-holding-heart text-2xl text-green-600"></i>
    </div>

    <div class="bg-purple-100/70 border-l-4 border-purple-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Volunteers</p>
        <p class="text-2xl font-bold text-purple-700"><%= volunteers %></p>
      </div>
      <i class="fas fa-user-friends text-2xl text-purple-600"></i>
    </div>

  </div>
</div>

<!-- ================= CAMPAIGN OVERVIEW ================= -->
<div class="max-w-7xl mx-auto mb-10 bg-slate-50/80 backdrop-blur rounded-2xl shadow-md p-6 border border-slate-200">

  <h2 class="text-xl font-bold text-slate-900 mb-5">Campaign Overview</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">

    <!-- TOTAL -->
    <div class="bg-slate-200/70 border-l-4 border-slate-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Total Campaigns</p>
        <p class="text-2xl font-bold text-slate-800"><%= totalCampaigns %></p>
      </div>
      <i class="fas fa-bullhorn text-2xl text-slate-600"></i>
    </div>

    <!-- PENDING -->
    <div class="bg-amber-100/70 border-l-4 border-amber-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Pending</p>
        <p class="text-2xl font-bold text-amber-700"><%= pendingCampaigns %></p>
      </div>
      <i class="fas fa-pencil-alt text-2xl text-amber-600"></i>
    </div>

    <!-- ACTIVE -->
    <div class="bg-blue-100/70 border-l-4 border-blue-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Active</p>
        <p class="text-2xl font-bold text-blue-700"><%= activeCampaigns %></p>
      </div>
      <i class="fas fa-bolt text-2xl text-blue-600"></i>
    </div>

    <!-- COMPLETED -->
    <div class="bg-emerald-100/70 border-l-4 border-emerald-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Completed</p>
        <p class="text-2xl font-bold text-emerald-700"><%= completedCampaigns %></p>
      </div>
      <i class="fas fa-check-circle text-2xl text-emerald-600"></i>
    </div>

    <!-- REJECTED -->
    <div class="bg-red-100/70 border-l-4 border-red-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Rejected</p>
        <p class="text-2xl font-bold text-red-700"><%= rejectedCampaigns %></p>
      </div>
      <i class="fas fa-times-circle text-2xl text-red-600"></i>
    </div>

  </div>
</div>

<!-- ================= QUICK ACTIONS ================= -->
<div class="max-w-7xl mx-auto bg-slate-50 rounded-2xl shadow-md p-8 mb-10 border border-slate-200">

  <h2 class="text-lg font-bold text-slate-800 mb-6">Quick Actions</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

    <a href="/coming-soon/users"
      class="bg-blue-600 hover:bg-blue-700 text-white rounded-xl p-6 text-center shadow-md">
      <i class="fas fa-users text-2xl"></i>
      <p class="mt-2 font-semibold">Manage Users</p>
    </a>

    <a href="/coming-soon/donations"
      class="bg-green-600 hover:bg-green-700 text-white rounded-xl p-6 text-center shadow-md">
      <i class="fas fa-hand-holding-heart text-2xl"></i>
      <p class="mt-2 font-semibold">Donations</p>
    </a>

    <a href="/coming-soon/requests"
      class="bg-purple-600 hover:bg-purple-700 text-white rounded-xl p-6 text-center shadow-md">
      <i class="fas fa-envelope text-2xl"></i>
      <p class="mt-2 font-semibold">Requests</p>
    </a>

    <a href="/admin/campaigns"
      class="bg-red-600 hover:bg-red-700 text-white rounded-xl p-6 text-center shadow-md">
      <i class="fas fa-bullhorn text-2xl"></i>
      <p class="mt-2 font-semibold">Campaigns</p>
    </a>

  </div>
</div>

<!-- ================= RECENT USERS (YOUR VERSION) ================= -->
<div class="max-w-7xl mx-auto bg-slate-50 rounded-2xl shadow-md p-6 border border-slate-200">

  <h2 class="text-lg font-bold text-slate-800 mb-4">Recent Registrations</h2>

  <% if(recentUsers.length === 0){ %>
    <p class="text-slate-500">No recent registrations.</p>
  <% } else { %>

    <ul class="divide-y divide-slate-200">

      <% recentUsers.forEach(user => { %>
        <li class="py-3 flex justify-between items-center hover:bg-slate-100 px-2 rounded transition">

          <div>
            <p class="text-slate-800 font-medium"><%= user.name %></p>
            <p class="text-sm text-slate-600">
              Registered as
              <span class="px-2 py-1 text-xs rounded 
                <%= user.role === 'donor' ? 'bg-green-100 text-green-700' : 'bg-purple-100 text-purple-700' %>">
                <%= user.role %>
              </span>
            </p>
          </div>

          <div class="text-sm text-slate-500">
            <%= new Date(user.createdAt).toLocaleString() %>
          </div>

        </li>
      <% }) %>

    </ul>

  <% } %>

</div>

</main>

<%- include('../partials/footer') %>

</body>
</html>