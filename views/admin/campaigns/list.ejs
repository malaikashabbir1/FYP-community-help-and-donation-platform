<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Campaigns</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen flex flex-col">

<%- include('../../partials/navbar') %>

<main class="flex-grow">

<div class="max-w-7xl mx-auto py-6 sm:py-10 px-3 sm:px-4">

  <!-- HEADER -->
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center mb-6 sm:mb-8">

    <h1 class="text-2xl sm:text-3xl font-bold">Campaigns</h1>

    <a href="/admin/campaigns/create"
       class="w-full sm:w-auto text-center bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
      + Create Campaign
    </a>

  </div>

  <!-- FLASH MESSAGE -->
  <% if (message) { %>
    <div id="alertBox"
         class="mb-6 px-4 py-3 rounded-lg shadow-sm flex justify-between items-center
         <%= message.type === 'success'
              ? 'bg-green-100 text-green-700 border border-green-300'
              : 'bg-red-100 text-green-700 border border-red-300' %>">

      <span class="text-sm font-medium"><%= message.text %></span>

      <button onclick="document.getElementById('alertBox').remove()"
              class="text-lg font-bold px-2">&times;</button>
    </div>
  <% } %>

  <form method="GET" action="/admin/campaigns" class="mb-6 flex flex-col sm:flex-row gap-3">

    <!-- SEARCH -->
    <input 
      type="text"
      name="search"
      placeholder="Search campaign..."
      class="w-full sm:w-1/2 px-3 py-2 border rounded-lg"
      value="<%= search || '' %>"
    />

    <!-- FILTER -->
    <select name="status" class="w-full sm:w-1/4 px-3 py-2 border rounded-lg">
      <option value="">All Status</option>
      <option value="draft" <%= status === 'draft' ? 'selected' : '' %>>Draft</option>
      <option value="active" <%= status === 'active' ? 'selected' : '' %>>Active</option>
      <option value="completed" <%= status === 'completed' ? 'selected' : '' %>>Completed</option>
    </select>

    <button class="bg-blue-600 text-white px-4 py-2 rounded-lg">
      Apply
    </button>

</form>
  <!-- GRID -->
  <% if (campaigns.length === 0) { %>

  <div class="text-center py-20">
    <h2 class="text-xl font-semibold text-gray-600">
      No campaigns found
    </h2>
    <p class="text-gray-500 mt-2">
      Try adjusting your search or filter
    </p>
  </div>

  <% } else { %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">

    <% campaigns.forEach(c => { %>

      <div class="bg-white rounded-xl shadow hover:shadow-xl hover:scale-[1.01] transition flex flex-col overflow-hidden">

        <!-- IMAGE -->
        <% if (c.image) { %>
          <img src="<%= c.image %>" class="h-40 sm:h-48 w-full object-cover">
        <% } else { %>
          <div class="h-40 sm:h-48 bg-gray-200 flex items-center justify-center text-gray-500 text-sm">
            No Image
          </div>
        <% } %>

        <div class="p-4 sm:p-5 flex flex-col flex-1">

          <!-- TITLE -->
          <h2 class="text-lg sm:text-xl font-semibold"><%= c.name %></h2>

          <!-- DESCRIPTION -->
          <p class="text-gray-600 text-sm mt-1 mb-4">
            <%= c.description %>
          </p>

          <!-- PROGRESS -->
          <%
            let progress = 0;
            if (c.goal > 0) {
              progress = Math.min((c.raised / c.goal) * 100, 100);
            }
          %>

          <div class="flex justify-between text-xs sm:text-sm mb-1">
            <span>Raised: Rs.<%= c.raised %></span>
            <span>Goal: Rs.<%= c.goal %></span>
          </div>

          <div class="w-full bg-gray-200 rounded-full h-2">
            <div class="bg-green-500 h-2 rounded-full"
                 style="width:<%= progress + '%' %>"></div>
          </div>

          <!-- STATUS -->
          <div class="mt-3 flex items-center justify-between gap-2">

            <div>
              <% if (c.status === 'draft') { %>
                <span class="bg-yellow-100 text-yellow-700 px-2 py-1 text-xs rounded">🟡 Draft </span>
              <% } else if (c.status === 'active') { %>
                <span class="bg-green-100 text-green-700 px-2 py-1 text-xs rounded">🟢 Live Campaign</span>
              <% } else { %>
                <span class="bg-blue-100 text-blue-700 px-2 py-1 text-xs rounded">🔵 Completed</span>
              <% } %>
            </div>

            <!-- ACTION BUTTONS -->
            <div>

              <% if (c.status === 'draft') { %>
                <form action="/admin/campaign/<%= c._id %>/approve" method="POST"
                      onsubmit="event.preventDefault(); openModal(this, 'Approve this campaign?')">
                  <button class="bg-green-600 text-white px-4 py-1.5 rounded-md hover:bg-green-700 text-sm">
                    Approve
                  </button>
                </form>

              <% } else if (c.status === 'active') { %>
                <form action="/admin/campaign/<%= c._id %>/complete" method="POST"
                      onsubmit="event.preventDefault(); openModal(this, 'Mark this campaign as completed?')">
                  <button class="bg-blue-600 text-white px-4 py-1.5 rounded-md hover:bg-blue-700 text-sm">
                    Complete
                  </button>
                </form>

              <% } else { %>
                <button disabled class="bg-gray-300 text-gray-600 px-4 py-1.5 rounded-md text-sm cursor-not-allowed">
                  Completed
                </button>
              <% } %>

            </div>

          </div>

          <!-- ACTIONS -->
          <div class="mt-4 flex flex-col sm:flex-row gap-2">

            <!-- EDIT -->
            <a href="/admin/campaigns/edit/<%= c._id %>"
               class="w-full text-center bg-yellow-500 text-white py-2.5 rounded hover:bg-yellow-600">
              Edit
            </a>

            <!-- DELETE -->
            <form action="/admin/campaigns/delete/<%= c._id %>" method="POST"
                  onsubmit="event.preventDefault(); openModal(this, 'Delete this campaign?')"
                  class="w-full">

              <button class="w-full bg-red-500 text-white py-2.5 rounded hover:bg-red-600">
                Delete
              </button>

            </form>

          </div>

        </div>
      </div>

    <% }) %>

  </div>

  <% } %>
</div>

</main>

<!-- MODAL -->
<div id="confirmModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">

  <div class="bg-white rounded-lg p-6 w-80 text-center shadow-lg">

    <h2 class="text-lg font-semibold mb-3">Confirm Action</h2>

    <p id="confirmText" class="text-sm text-gray-600 mb-5">Are you sure?</p>

    <div class="flex justify-center gap-3">

      <button onclick="closeModal()"
              class="px-4 py-2 bg-gray-300 rounded hover:bg-gray-400">
        Cancel
      </button>

      <button id="confirmBtn"
              class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700">
        Yes
      </button>

    </div>

  </div>

</div>

<!-- SCRIPTS -->
<script>

  let currentForm = null;

  function openModal(form, message) {
    currentForm = form;
    document.getElementById('confirmText').innerText = message;
    document.getElementById('confirmModal').classList.remove('hidden');
    document.getElementById('confirmModal').classList.add('flex');
  }

  function closeModal() {
    document.getElementById('confirmModal').classList.add('hidden');
  }

  document.getElementById('confirmBtn').addEventListener('click', () => {
    if (currentForm) currentForm.submit();
  });

  document.getElementById('confirmModal').addEventListener('click', (e) => {
    if (e.target.id === 'confirmModal') {
      closeModal();
    }
  });

  setTimeout(() => {
    const alert = document.getElementById('alertBox');
    if (alert) alert.remove();
  }, 3000);

</script>

<%- include('../../partials/footer') %>

</body>
</html>