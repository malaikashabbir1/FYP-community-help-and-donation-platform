<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Review Campaign</title>

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen flex flex-col">

  <!-- NAVBAR -->
  <header class="bg-blue-600 text-white shadow">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex justify-between items-center">
      <h1 class="text-lg sm:text-xl font-bold text-emerald-300">
        Admin Panel
      </h1>

      <a href="/admin/campaigns" class="text-sm hover:underline">
        Back to Campaigns
      </a>
    </div>
  </header>

  <!-- MAIN -->
  <main class="flex-1 px-3 sm:px-6 py-4 sm:py-6">

    <div class="w-full max-w-3xl mx-auto">

      <!-- FLASH MESSAGE -->
      <% if (message) { %>
        <div id="alertBox"
          class="mb-4 px-4 py-3 rounded-lg shadow-sm flex justify-between items-center
          <%= message.type === 'success'
              ? 'bg-green-100 text-green-700 border border-green-300'
              : 'bg-red-100 text-red-700 border border-red-300' %>">

          <span class="text-sm font-medium"><%= message.text %></span>

          <button onclick="document.getElementById('alertBox').remove()"
            class="text-lg font-bold px-2">&times;</button>
        </div>
      <% } %>

      <!-- CARD -->
      <div class="bg-white rounded-xl shadow border border-gray-200 overflow-hidden">

        <!-- HEADER -->
        <div class="p-4 sm:p-5 border-b">
          <h1 class="text-lg sm:text-2xl font-bold text-gray-800">
            Campaign Review
          </h1>
          <p class="text-xs sm:text-sm text-gray-500 mt-1">
            Approve or reject this campaign
          </p>
        </div>

        <!-- CONTENT -->
        <div class="p-4 sm:p-5 space-y-4">

          <!-- TITLE + DESCRIPTION -->
          <div>
            <h2 class="text-base sm:text-xl font-semibold text-gray-900">
              <%= campaign?.name || 'No Title' %>
            </h2>

            <p class="text-sm text-gray-600 mt-1 leading-snug">
              <%= campaign?.description || 'No description available' %>
            </p>
          </div>

          <!-- INFO -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">

            <div class="bg-gray-50 p-3 rounded border">
              <p class="text-xs text-gray-500">Created By</p>
              <p class="font-medium text-gray-800">
                <%= campaign?.createdBy?.name || 'Unknown User' %>
              </p>
            </div>

            <div class="bg-gray-50 p-3 rounded border">
              <p class="text-xs text-gray-500">Goal</p>
              <p class="font-medium text-gray-800">
                Rs. <%= campaign?.goal || 0 %>
              </p>
            </div>

          </div>

          <!-- IMAGE -->
          <% if (campaign?.image) { %>
            <div>
              <img
                src="<%= campaign.image %>"
                class="w-full max-h-56 sm:max-h-64 object-cover rounded-lg border"
              >
            </div>
          <% } %>

          <!-- ACTIONS -->
          <div class="pt-4 border-t space-y-3">

            <h3 class="text-base sm:text-lg font-semibold text-gray-800">
              Actions
            </h3>

            <% if (campaign?.status === 'pending') { %>

              <div class="flex flex-col sm:flex-row gap-3">

                <!-- APPROVE -->
                <form method="POST"
                      action="/admin/campaigns/<%= campaign._id %>/approve"
                      class="w-full sm:w-auto">

                  <button
                    class="w-full bg-green-600 hover:bg-green-700 text-white py-2 px-4 rounded-lg text-sm transition">
                    Approve
                  </button>

                </form>

                <!-- REJECT -->
                <form method="POST"
                      action="/admin/campaigns/<%= campaign._id %>/reject"
                      class="w-full space-y-2">

                  <textarea
                    name="reason"
                    rows="2"
                    required
                    placeholder="Enter rejection reason..."
                    class="w-full border border-gray-300 rounded-lg p-2 text-sm focus:ring-2 focus:ring-red-400 outline-none resize-none"
                  ></textarea>

                  <button
                    class="w-full bg-red-600 hover:bg-red-700 text-white py-2 rounded-lg text-sm transition">
                    Reject
                  </button>

                </form>

              </div>

            <% } else if (campaign?.status === 'active') { %>

              <!-- COMPLETE BUTTON -->
              <form method="POST"
                    action="/admin/campaigns/<%= campaign._id %>/complete">

                <button
                  class="w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-lg text-sm transition">
                  Mark as Completed
                </button>

              </form>

            <% } else { %>

              <!-- NO ACTION -->
              <p class="text-sm text-gray-500">
                No actions available for this campaign.
              </p>

            <% } %>

          </div>

        </div>

      </div>

    </div>

  </main>

  <!-- FOOTER -->
  <footer class="bg-white border-t mt-6">
    <div class="max-w-6xl mx-auto px-4 py-3 text-center text-xs text-gray-500">
      © 2026 Community Help Platform
    </div>
  </footer>

  <!-- AUTO HIDE FLASH -->
  <script>
    setTimeout(() => {
      const alertBox = document.getElementById('alertBox');
      if (alertBox) {
        alertBox.style.transition = "opacity 0.5s ease";
        alertBox.style.opacity = "0";
        setTimeout(() => alertBox.remove(), 500);
      }
    }, 3000);
  </script>

</body>
</html>