<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Donor Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" href="/css/output.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>


<body>
  <%- include('../partials/navbar') %>

<!-- HEADER (IDENTICAL STYLE TO VOLUNTEER) -->
<div class="max-w-7xl mx-auto mt-8 text-center px-4">
  <h1 class="text-3xl font-bold text-gray-800">Donor Dashboard</h1>
  <p class="text-gray-600 mt-1">
    Welcome, <span class="font-semibold"><%= user.name %></span>
  </p>
</div>



  <!-- FLASH MESSAGE -->
  <% if (message) { %>
    <div id="alertBox"
      class="mb-6 px-4 py-3 rounded-lg shadow-sm flex justify-between items-center
      <%= message.type === 'success'
          ? 'bg-green-100 text-green-700 border border-green-300'
          : 'bg-red-100 text-red-700 border border-red-300' %>">

      <span class="text-sm font-medium"><%= message.text %></span>

      <button onclick="document.getElementById('alertBox').remove()"
        class="text-lg font-bold px-2">&times;</button>
    </div>
  <% } %>

<!-- QUICK ACTIONS (EXACT SAME GRID SYSTEM AS VOLUNTEER) -->
<div class="max-w-7xl mx-auto mt-8 grid grid-cols-1 md:grid-cols-3 gap-5 px-4">

  <a href="/campaigns/live"
     class="bg-blue-600 text-white p-5 rounded-xl text-center font-semibold hover:bg-blue-700 shadow-md transition">
    <div>Live Campaigns</div>
  </a>

  <a href="/donor/recommended"
     class="bg-green-600 text-white p-5 rounded-xl text-center font-semibold hover:bg-green-700 shadow-md transition">
    <div>Recommended</div>
  </a>

  <a href="/donor/donations"
     class="bg-purple-600 text-white p-5 rounded-xl text-center font-semibold hover:bg-purple-700 shadow-md transition">
    <div>My Donations</div>
  </a>

</div>

<!-- DONATION OVERVIEW (COPY OF VOLUNTEER CARD STRUCTURE) -->
<div class="max-w-7xl mx-auto mt-10 mb-10 bg-slate-50/80 backdrop-blur rounded-2xl shadow-md p-6 border border-slate-200">

  <h2 class="text-xl font-bold text-slate-900 mb-5">Donation Overview</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

    <div class="bg-blue-100/70 border-l-4 border-blue-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Total Donations</p>
        <p class="text-2xl font-bold text-blue-700"><%= stats.totalDonations %></p>
      </div>
      <i class="fas fa-hand-holding-heart text-2xl text-blue-600"></i>
    </div>

    <div class="bg-green-100/70 border-l-4 border-green-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Total Amount</p>
        <p class="text-2xl font-bold text-green-700">Rs <%= stats.totalAmount %></p>
      </div>
      <i class="fas fa-coins text-2xl text-green-600"></i>
    </div>

    <div class="bg-purple-100/70 border-l-4 border-purple-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Completed</p>
        <p class="text-2xl font-bold text-purple-700"><%= stats.completedDonations %></p>
      </div>
      <i class="fas fa-check-circle text-2xl text-purple-600"></i>
    </div>

    <div class="bg-indigo-100/70 border-l-4 border-indigo-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Active Campaigns</p>
        <p class="text-2xl font-bold text-indigo-700"><%= stats.activeCampaigns %></p>
      </div>
      <i class="fas fa-bolt text-2xl text-indigo-600"></i>
    </div>

  </div>
</div>

<!-- RECENT ACTIVITY (same pattern as volunteer sections) -->
<div class="max-w-7xl mx-auto mb-10 bg-slate-50/80 backdrop-blur rounded-2xl shadow-md p-6 border border-slate-200">

  <h2 class="text-xl font-bold text-slate-900 mb-5">Recent Donations</h2>

  

</div>

</main>
<%- include('../partials/footer') %>

</body>
</html>