<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Volunteer Dashboard</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body class="bg-gray-100 min-h-screen flex flex-col">

<%- include('../partials/navbar') %>

<main class="flex-grow">

<!-- HEADER -->
<div class="max-w-7xl mx-auto mt-8 text-center px-4">
  <h1 class="text-3xl font-bold text-gray-800">Volunteer Dashboard</h1>
  <p class="text-gray-600 mt-1">
    Welcome, <span class="font-semibold"><%= user.name || 'Volunteer' %></span>
  </p>
</div>

<!-- QUICK ACTIONS -->
<div class="max-w-7xl mx-auto mt-8 grid grid-cols-1 md:grid-cols-3 gap-5 px-4">

  <a href="/volunteer/campaigns/create"
     class="bg-blue-600 text-white p-5 rounded-xl text-center font-semibold hover:bg-blue-700 shadow-md transition">
    <i class="fas fa-plus mb-2"></i>
    <div>Create Campaign</div>
  </a>

  <a href="/volunteer/campaigns/my"
     class="bg-purple-600 text-white p-5 rounded-xl text-center font-semibold hover:bg-purple-700 shadow-md transition">
    <i class="fas fa-folder-open mb-2"></i>
    <div>My Campaigns</div>
  </a>

  <a href="/campaigns/live"
     class="bg-green-600 text-white p-5 rounded-xl text-center font-semibold hover:bg-green-700 shadow-md transition">
    <i class="fas fa-bolt mb-2"></i>
    <div>Explore Campaigns</div>
  </a>

</div>


<!-- MY CAMPAIGN OVERVIEW -->

<div class="max-w-7xl mx-auto mt-10 mb-10 bg-slate-50/80 backdrop-blur rounded-2xl shadow-md p-6 border border-slate-200">

  <h2 class="text-xl font-bold text-slate-900 mb-5">My Campaign Overview</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-4">

    <!-- TOTAL -->
    <div class="bg-blue-100/70 border-l-4 border-blue-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Total Campaigns</p>
        <p class="text-2xl font-bold text-blue-700">
          <%= stats?.myStats?.totalCampaigns || 0 %>
        </p>
      </div>
      <i class="fas fa-layer-group text-2xl text-blue-600"></i>
    </div>

    <!-- DRAFT -->
    <div class="bg-yellow-100/70 border-l-4 border-yellow-500 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Drafts</p>
        <p class="text-2xl font-bold text-yellow-700">
          <%= stats?.myStats?.drafts || 0 %>
        </p>
      </div>
      <i class="fas fa-pen text-2xl text-yellow-600"></i>
    </div>

    <!-- PENDING -->
    <div class="bg-indigo-100/70 border-l-4 border-indigo-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Pending</p>
        <p class="text-2xl font-bold text-indigo-700">
          <%= stats?.myStats?.pending || 0 %>
        </p>
      </div>
      <i class="fas fa-clock text-2xl text-indigo-600"></i>
    </div>

    <!-- ACTIVE -->
    <div class="bg-green-100/70 border-l-4 border-green-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Active</p>
        <p class="text-2xl font-bold text-green-700">
          <%= stats?.myStats?.active || 0 %>
        </p>
      </div>
      <i class="fas fa-bolt text-2xl text-green-600"></i>
    </div>

    <!-- COMPLETED -->
    <div class="bg-blue-100/70 border-l-4 border-blue-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Completed</p>
        <p class="text-2xl font-bold text-blue-700">
          <%= stats?.myStats?.completed || 0 %>
        </p>
      </div>
      <i class="fas fa-check-circle text-2xl text-blue-600"></i>
    </div>

    <!-- REJECTED -->
    <div class="bg-red-100/70 border-l-4 border-red-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Rejected</p>
        <p class="text-2xl font-bold text-red-700">
          <%= stats?.myStats?.rejected || 0 %>
        </p>
      </div>
      <i class="fas fa-times-circle text-2xl text-red-600"></i>
    </div>

  </div>
</div>


<!-- PLATFORM ACTIVITY -->

<div class="max-w-7xl mx-auto mb-10 bg-slate-50/80 backdrop-blur rounded-2xl shadow-md p-6 border border-slate-200">

  <h2 class="text-xl font-bold text-slate-900 mb-5">Platform Activity</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

    <!-- LIVE -->
    <div class="bg-green-100/70 border-l-4 border-green-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Live Campaigns</p>
        <p class="text-2xl font-bold text-green-700">
          <%= stats?.platformStats?.liveCampaigns || 0 %>
        </p>
      </div>
      <i class="fas fa-bolt text-2xl text-green-600"></i>
    </div>

    <!-- COMPLETED -->
    <div class="bg-blue-100/70 border-l-4 border-blue-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Completed Campaigns</p>
        <p class="text-2xl font-bold text-blue-700">
          <%= stats?.platformStats?.completedCampaigns || 0 %>
        </p>
      </div>
      <i class="fas fa-check-circle text-2xl text-blue-600"></i>
    </div>

    <!-- VOLUNTEERS -->
    <div class="bg-purple-100/70 border-l-4 border-purple-600 rounded-xl p-6 flex justify-between">
      <div>
        <p class="text-sm text-slate-600">Total Volunteers</p>
        <p class="text-2xl font-bold text-purple-700">
          <%= stats?.platformStats?.totalVolunteers || 0 %>
        </p>
      </div>
      <i class="fas fa-users text-2xl text-purple-600"></i>
    </div>

  </div>
</div>

<!-- FLOATING CTA -->
<a href="/campaigns/live"
   class="fixed bottom-6 right-6 bg-green-600 text-white px-10 py-5 rounded-full shadow-lg 
          flex items-center gap-2 z-50
          hover:bg-green-700 transition-all duration-300
          cta-pulse">

  <i class="fas fa-bolt"></i>
  <span class="hidden sm:inline text-lg font-semibold">Explore Campaigns</span>

</a>

</main>

<%- include('../partials/footer') %>

<style>
@keyframes softPulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 0 15px 5px rgba(34, 197, 94, 0.2);
  }
}

.cta-pulse {
  animation: softPulse 2.5s infinite;
}
</style>

</body>
</html>