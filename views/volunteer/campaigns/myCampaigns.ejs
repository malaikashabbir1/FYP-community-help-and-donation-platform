<!DOCTYPE html>
<html>
<head>
  <title>My Campaigns</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen flex flex-col">

<%- include('../../partials/navbar') %>

<main class="flex-grow">

<div class="max-w-7xl mx-auto py-6 sm:py-10 px-3 sm:px-4">

  <!-- HEADER -->
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center mb-6 sm:mb-8">
    
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">My Campaigns</h1>
      <p class="text-sm text-gray-500">Manage your campaigns easily</p>
    </div>

    <a href="/volunteer/campaigns/create"
      class="w-full sm:w-auto text-center bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
      + Create Campaign
    </a>

  </div>

  <!-- FLASH -->
  <% if (message) { %>
    <div id="alertBox"
      class="mb-6 px-4 py-3 rounded-lg shadow-sm flex justify-between items-center
      <%= message.type === 'success'
        ? 'bg-green-100 text-green-700 border border-green-300'
        : 'bg-red-100 text-red-700 border border-red-300' %>">

      <span class="text-sm font-medium"><%= message.text %></span>

      <button onclick="document.getElementById('alertBox').remove()"
        class="text-lg font-bold px-2">&times;</button>
    </div>
  <% } %>

  <!-- EMPTY -->
  <% if (campaigns.length === 0) { %>

    <div class="text-center py-20">
      <h2 class="text-xl font-semibold text-gray-600">No campaigns yet</h2>
      <p class="text-gray-500 mt-2">Create your first campaign</p>
    </div>

  <% } else { %>

  <!-- GRID -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 sm:gap-6">

    <% campaigns.forEach(c => { %>

      <div class="bg-white rounded-xl shadow hover:shadow-xl transition flex flex-col h-full overflow-hidden">

        <!-- IMAGE -->
        <% if (c.image) { %>
          <img src="<%= c.image %>" class="h-40 sm:h-48 w-full object-cover">
        <% } else { %>
          <div class="h-40 sm:h-48 bg-gray-200 flex items-center justify-center text-gray-500 text-sm">
            No Image
          </div>
        <% } %>

        <!-- BODY -->
        <div class="p-4 sm:p-5 flex flex-col flex-1">

          <!-- TITLE -->
          <h2 class="text-lg sm:text-xl font-semibold leading-snug line-clamp-2 min-h-[48px]">
            <%= c.name %>
          </h2>

          <!-- DESCRIPTION -->
          <p class="text-gray-600 text-sm mt-1 line-clamp-3 min-h-[40px]">
            <%= c.description %>
          </p>

          <!-- STATUS + REASON -->
          <div class="mt-3 space-y-2">

            <% if (c.status === 'draft') { %>
              <span class="bg-yellow-100 text-yellow-700 px-2 py-1 text-xs rounded">Draft</span>

            <% } else if (c.status === 'pending') { %>
              <span class="bg-orange-100 text-orange-700 px-2 py-1 text-xs rounded">Pending</span>

            <% } else if (c.status === 'active') { %>
              <span class="bg-green-100 text-green-700 px-2 py-1 text-xs rounded">Active</span>

            <% } else if (c.status === 'rejected') { %>
              <span class="bg-red-100 text-red-700 px-2 py-1 text-xs rounded">Rejected</span>
            <% } else { %>
              <span class="bg-blue-100 text-blue-700 px-2 py-1 text-xs rounded">Completed</span>
            <% } %>

          </div>

          <!-- PUSH CONTENT DOWN -->
          <div class="flex-1"></div>

          <!-- PROGRESS -->
          <%
            let progress = c.goal > 0 ? Math.min((c.raised / c.goal) * 100, 100) : 0;
          %>

          <div class="mt-3">
            <div class="flex justify-between text-xs sm:text-sm mb-1">
              <span>Rs. <%= c.raised %></span>
              <span>Rs. <%= c.goal %></span>
            </div>

            <div class="w-full bg-gray-200 h-2 rounded-full">
              <div class="bg-green-500 h-2 rounded-full"
                   style="width:<%= progress + '%' %>"></div>
            </div>
          </div>

          <!-- ACTIONS -->
          <div class="mt-4 flex gap-2">

            <% if (c.status === 'draft') { %>

              <a href="/volunteer/campaigns/edit/<%= c._id %>"
                class="flex-1 text-center bg-gray-200 hover:bg-gray-300 py-2 rounded text-sm">
                Edit
              </a>

              <form method="POST" action="/volunteer/campaigns/<%= c._id %>/submit" class="flex-1">
                <button class="w-full bg-green-600 hover:bg-green-700 text-white py-2 rounded text-sm">
                  Submit
                </button>
              </form>

            <% } else if (c.status === 'rejected') { %>

              <a href="/volunteer/campaigns/edit/<%= c._id %>?resubmit=true"
                class="w-full text-center bg-yellow-500 hover:bg-yellow-600 text-white py-2 rounded text-sm">
                Fix & Resubmit
              </a>

            <% } else if (c.status === 'pending') { %>

              <div class="w-full text-center text-xs text-orange-600 py-2">
                Waiting for review...
              </div>

            <% } else { %>

              <div class="w-full text-center text-xs text-gray-500 py-2">
                No actions
              </div>

            <% } %>

          </div>

        </div>

      </div>

    <% }) %>

  </div>

  <% } %>

</div>

</main>

<%- include('../../partials/footer') %>

<script>
  setTimeout(() => {
    const alertBox = document.getElementById('alertBox');
    if (alertBox) {
      alertBox.style.transition = "opacity 0.5s ease";
      alertBox.style.opacity = "0";
      setTimeout(() => alertBox.remove(), 500);
    }
  }, 3000);
</script>

</body>
</html>