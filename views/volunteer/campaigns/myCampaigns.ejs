<!DOCTYPE html>
<html>
<head>
  <title>My Campaigns</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen flex flex-col">

<%- include('../../partials/navbar') %>

<main class="flex-grow">

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

  <!-- HEADER -->
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">

    <div>
      <h1 class="text-3xl font-bold text-gray-800">My Campaigns</h1>
      <p class="text-sm text-gray-500 mt-1">
        Manage your campaigns easily
      </p>
    </div>

    <a href="/volunteer/campaigns/create"
       class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg text-center w-full sm:w-auto">
      + Create Campaign
    </a>

  </div>

  <!-- FLASH MESSAGE -->
  <% if (message) { %>
    <div id="alertBox"
      class="mb-6 px-4 py-3 rounded-lg shadow flex justify-between items-center
      <%= message.type === 'success'
          ? 'bg-green-100 text-green-700 border border-green-300'
          : 'bg-red-100 text-red-700 border border-red-300' %>">

      <span><%= message.text %></span>

      <button onclick="document.getElementById('alertBox').remove()"
        class="font-bold text-lg">&times;</button>

    </div>
  <% } %>

  <!-- EMPTY STATE -->
  <% if (campaigns.length === 0) { %>

    <div class="text-center py-20 bg-white rounded-xl shadow">
      <h2 class="text-xl font-semibold text-gray-700">No campaigns yet</h2>
      <p class="text-gray-500 mt-2">Create your first campaign</p>
    </div>

  <% } else { %>

  <!-- GRID -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

    <% campaigns.forEach(c => { %>

      <div class="bg-white rounded-xl shadow hover:shadow-lg transition overflow-hidden flex flex-col">

        <!-- IMAGE -->
        <% if (c.image) { %>
          <img src="<%= c.image %>" class="h-40 w-full object-cover">
        <% } else { %>
          <div class="h-40 bg-gray-200 flex items-center justify-center text-gray-500">
            No Image
          </div>
        <% } %>

        <div class="p-5 flex flex-col flex-1">

          <!-- TITLE -->
          <h2 class="text-lg font-semibold text-gray-800">
            <%= c.name %>
          </h2>

          <!-- DESCRIPTION -->
          <p class="text-sm text-gray-600 mt-1">
            <%= c.description %>
          </p>

          <!-- STATUS -->
          <div class="mt-3">
            <% if (c.status === 'draft') { %>
              <span class="bg-yellow-100 text-yellow-700 px-2 py-1 text-xs rounded">Draft</span>
            <% } else if (c.status === 'pending') { %>
              <span class="bg-orange-100 text-orange-700 px-2 py-1 text-xs rounded">Pending</span>
            <% } else if (c.status === 'active') { %>
              <span class="bg-green-100 text-green-700 px-2 py-1 text-xs rounded">Active</span>
            <% } else if (c.status === 'rejected') { %>
              <span class="bg-red-100 text-red-700 px-2 py-1 text-xs rounded">Rejected</span>
            <% } else { %>
              <span class="bg-blue-100 text-blue-700 px-2 py-1 text-xs rounded">Completed</span>
            <% } %>
          </div>

          <!-- PROGRESS -->
          <%
            let progress = c.goal > 0 ? Math.min((c.raised / c.goal) * 100, 100) : 0;
          %>

          <div class="mt-3">
            <div class="flex justify-between text-xs text-gray-600">
              <span>Rs. <%= c.raised %></span>
              <span>Rs. <%= c.goal %></span>
            </div>

            <div class="w-full bg-gray-200 h-2 rounded-full mt-1">
              <div class="bg-green-500 h-2 rounded-full"
                   style="width:<%= progress + '%' %>"></div>
            </div>
          </div>

          <!-- ACTIONS -->
          <div class="mt-4 grid grid-cols-2 gap-2">

            <% if (c.status === 'draft') { %>

              <!-- EDIT -->
              <a href="/volunteer/campaigns/edit/<%= c._id %>"
                 class="text-center bg-gray-200 hover:bg-gray-300 text-gray-800 py-2 rounded text-xs font-medium">
                Edit
              </a>

              <!-- SUBMIT -->
              <form method="POST"
                    action="/volunteer/campaigns/<%= c._id %>/submit"
                    class="w-full">

                <button type="submit"
                        class="w-full bg-green-600 hover:bg-green-700 text-white py-2 rounded text-xs font-medium">
                  Submit
                </button>

              </form>

            <% } else if (c.status === 'rejected') { %>

              <a href="/volunteer/campaigns/edit/<%= c._id %>"
                 class="col-span-2 text-center bg-yellow-500 hover:bg-yellow-600 text-white py-2 rounded text-xs font-medium">
                Fix & Resubmit
              </a>

            <% } else if (c.status === 'pending') { %>

              <div class="col-span-2 text-center text-xs text-orange-600 py-2">
                Waiting for admin review...
              </div>

            <% } else { %>

              <div class="col-span-2 text-center text-xs text-gray-500 py-2">
                No actions available
              </div>

            <% } %>

          </div>

        </div>

      </div>

    <% }) %>

  </div>

  <% } %>

</div>

</main>

<%- include('../../partials/footer') %>

<script>
  setTimeout(() => {
    const alertBox = document.getElementById('alertBox');
    if (alertBox) {
      alertBox.style.transition = "opacity 0.5s ease";
      alertBox.style.opacity = "0";

      setTimeout(() => {
        alertBox.remove();
      }, 500);
    }
  }, 3000); // 3 seconds
</script>

</body>
</html>