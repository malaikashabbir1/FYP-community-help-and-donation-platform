<!DOCTYPE html>
<html>
<head>
  <title>Edit Campaign</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen flex flex-col">

<%- include('../../partials/navbar') %>

<main class="flex-grow">

<div class="max-w-xl mx-auto px-4 py-8">

  <h1 class="text-xl sm:text-3xl font-bold mb-6">
    Edit Campaign
  </h1>

  <div class="bg-white p-4 sm:p-6 rounded-xl shadow">

    <form action="/volunteer/campaigns/edit/<%= campaign._id %>" method="POST" enctype="multipart/form-data" class="space-y-4" >

      <!-- Name -->
      <input type="text" name="name"
        value="<%= campaign.name %>"
        class="w-full border p-3 rounded"
        required>

      <!-- Description -->
      <textarea name="description"
        class="w-full border p-3 rounded"><%= campaign.description %></textarea>

      <!-- Goal -->
      <input type="number" name="goal"
        value="<%= campaign.goal %>"
        class="w-full border p-3 rounded"
        required>

      <!-- Image -->
      <input type="file" name="image" accept="image/*"
        value="<%= campaign.image %>"
        class="w-full border p-3 rounded">

      <!-- Button -->
      <button class="w-full bg-blue-600 text-white py-3 rounded-lg hover:bg-blue-700">
        Update Campaign
      </button>

    </form>

  </div>

</div>

</main>

<%- include('../../partials/footer') %>

</body>
</html>